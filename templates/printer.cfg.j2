{%- endif %}
fade_start: {{ user.bed_mesh.fade_start | default(1) }} # Z height at which to start fading mesh leveling
fade_end: {{ user.bed_mesh.fade_end | default(10) }} # Z height at which mesh leveling is completely disabled
fade_target: {{ user.bed_mesh.fade_target | default(0) }} # Target Z offset to fade towards
{%- endif %}

