enable_pin: {{ pins['stepper_x'].get('enable_pin', 'TODO') }} # Enable pin for the stepper driver
{%- endif %}
microsteps: 16 # Number of microsteps per full step
rotation_distance: {{ user.rotation_distance_x | default(40) }} # Distance in mm the axis travels per full rotation of the motor
{%- if user.gear_ratio_x %}
gear_ratio: {{ user.gear_ratio_x }} # Gear ratio of the axis
{%- endif %}
