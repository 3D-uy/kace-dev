{%- if user.probe | lower == 'bltouch' or 'control_pin' in probe_sec %}
control_pin: {{ probe_sec.get('control_pin', 'TODO') }} # Pin connected to the probe control
{%- endif %}
x_offset: {{ user.probe_x_offset | default(0) }} # distance from nozzle to probe in X (mm) --- set in KACE wizard --- (re-measure physically if probe is moved)
y_offset: {{ user.probe_y_offset | default(0) }} # distance from nozzle to probe in Y (mm) --- set in KACE wizard --- (re-measure physically if probe is moved)
z_offset: 0 # nozzle to bed distance (mm) --- manual configuration --- (set using PROBE_CALIBRATE)

[safe_z_home]
home_xy_position: {{ user.x_size | int / 2 }}, {{ user.y_size | int / 2 }} # XY position to move to before homing Z
speed: 50 # Speed at which the toolhead is moved to the safe Z home coordinate
z_hop: 10 # Distance (in mm) to lift the Z axis prior to homing
z_hop_speed: 5 # Speed (in mm/s) at which the Z axis is lifted prior to homing

[bed_mesh]
speed: {{ user.bed_mesh.speed | default(120) }} # Probe speed in mm/s
horizontal_move_z: {{ user.bed_mesh.horizontal_move_z | default(5) }} # Z height before moving to next probe point
mesh_min: {{ user.bed_mesh.mesh_min }} # Probing area minimum (derived from physical limits)
mesh_max: {{ user.bed_mesh.mesh_max }} # Probing area maximum (derived from physical limits)
probe_count: {{ user.bed_mesh.probe_count }} # Probe grid size (NxN derived from bed size)
algorithm: {{ user.bed_mesh.algorithm }} # Interpolation algorithm
{%- if user.bed_mesh.algorithm == 'bicubic' %}
