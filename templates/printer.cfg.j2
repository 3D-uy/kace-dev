# --------------------------------------------------
# Probe & Bed Leveling
# --------------------------------------------------
{%- if user.probe != 'None' %}
[{{ user.probe | lower }}]
{%- set probe_sec = pins.get('bltouch', pins.get('probe', {})) %}
